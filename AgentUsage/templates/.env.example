# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# SECURITY NOTICE:
# 1. Copy this file to your project root as .env
# 2. Replace ALL placeholder values with real credentials
# 3. NEVER commit .env files with real credentials to version control
# 4. Ensure .env is listed in .gitignore
# =============================================================================

# API Keys - Replace with your actual keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Database - Replace with your actual connection string
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost/YOUR_DATABASE

# Redis Cache
REDIS_URL=redis://localhost:6379

# AWS Credentials - Replace with your actual credentials
AWS_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_KEY=YOUR_AWS_SECRET_KEY_HERE
AWS_REGION=us-east-1

# Application Configuration
APP_ENV=development
PORT=3000
DEBUG=true
LOG_LEVEL=info

# Security - Generate a secure random string (minimum 32 characters)
JWT_SECRET=YOUR_JWT_SECRET_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRATION=3600

# External Services - Replace with your actual keys
STRIPE_API_KEY=YOUR_STRIPE_API_KEY_HERE
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE
